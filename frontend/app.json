{
  "expo": {
    "name": "Engine Eye",
    "slug": "engine-eye",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.engineeye.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0e"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.engineeye.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "019342f0-d46a-4c27-824c-7f5a8f0bbff9"
      }
    }
  }
}
